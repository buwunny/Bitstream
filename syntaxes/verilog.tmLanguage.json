{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Verilog",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#directives" },
    { "include": "#system-tasks" },
    { "include": "#attributes" },
    { "include": "#numbers" },
    { "include": "#module-decl" },
    { "include": "#instantiation" },
    { "include": "#port-decl" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.verilog",
          "begin": "//",
          "end": "$",
          "patterns": [
            { "name": "keyword.other.todo.verilog", "match": "\\b(TODO|FIXME|XXX|HACK|NOTE)\\b" }
          ]
        },
        {
          "name": "comment.block.verilog",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "name": "keyword.other.todo.verilog", "match": "\\b(TODO|FIXME|XXX|HACK|NOTE)\\b" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.verilog",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.verilog", "match": "\\\\(n|t|r|0|\\\\|\"|[0-7]{1,3}|x[0-9a-fA-F]{1,2})" },
            { "name": "constant.other.placeholder.verilog", "match": "%[-0+# ]*\\d*(\\.\\d+)?[bBdDhHoOcCsStTeEfFgGmMlLuUvVzZ%]" }
          ]
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.preprocessor.verilog",
          "match": "^\\s*(`)(celldefine|default_nettype|define|else|elsif|endcelldefine|endif|ifdef|ifndef|include|line|nounconnected_drive|resetall|timescale|unconnected_drive|undef|undefineall|pragma|begin_keywords|end_keywords)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.directive.verilog" },
            "2": { "name": "keyword.control.directive.verilog" }
          }
        },
        {
          "name": "entity.name.function.preprocessor.verilog",
          "match": "`[a-zA-Z_]\\w*"
        }
      ]
    },
    "system-tasks": {
      "patterns": [
        {
          "name": "support.function.system.verilog",
          "match": "\\$[a-zA-Z_]\\w*"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.verilog",
          "begin": "\\(\\*",
          "end": "\\*\\)",
          "patterns": [
            { "name": "variable.parameter.attribute.verilog", "match": "[a-zA-Z_]\\w*" },
            { "include": "#strings" },
            { "include": "#numbers" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.sized.verilog",
          "match": "\\b(\\d+)?'[sS]?[bB][\\s]*[01xXzZ?_]+\\b",
          "captures": {
            "1": { "name": "constant.numeric.size.verilog" }
          }
        },
        {
          "name": "constant.numeric.sized.verilog",
          "match": "\\b(\\d+)?'[sS]?[hH][\\s]*[0-9a-fA-FxXzZ?_]+\\b",
          "captures": {
            "1": { "name": "constant.numeric.size.verilog" }
          }
        },
        {
          "name": "constant.numeric.sized.verilog",
          "match": "\\b(\\d+)?'[sS]?[oO][\\s]*[0-7xXzZ?_]+\\b",
          "captures": {
            "1": { "name": "constant.numeric.size.verilog" }
          }
        },
        {
          "name": "constant.numeric.sized.verilog",
          "match": "\\b(\\d+)?'[sS]?[dD][\\s]*[0-9xXzZ?_]+\\b",
          "captures": {
            "1": { "name": "constant.numeric.size.verilog" }
          }
        },
        {
          "name": "constant.numeric.real.verilog",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.real.verilog",
          "match": "\\b\\d[\\d_]*[eE][+-]?\\d+\\b"
        },
        {
          "name": "constant.numeric.decimal.verilog",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "module-decl": {
      "patterns": [
        {
          "match": "\\b(module|macromodule|primitive)\\s+([a-zA-Z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.module.verilog" },
            "2": { "name": "entity.name.type.module.verilog" }
          }
        }
      ]
    },
    "instantiation": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_]\\w*)\\s+([a-zA-Z_]\\w*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.type.module.verilog" },
            "2": { "name": "variable.other.instance.verilog" }
          }
        }
      ]
    },
    "port-decl": {
      "patterns": [
        {
          "name": "storage.modifier.port.verilog",
          "match": "\\b(input|output|inout)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.verilog",
          "match": "\\b(always|if|else|case|casex|casez|default|endcase|for|while|forever|repeat|begin|end|initial|disable|wait|fork|join)\\b"
        },
        {
          "name": "keyword.declaration.verilog",
          "match": "\\b(module|endmodule|macromodule|primitive|endprimitive|function|endfunction|task|endtask|generate|endgenerate|specify|endspecify|table|endtable|config|endconfig|wire|reg|integer|real|realtime|time|parameter|localparam|defparam|specparam|assign|deassign|genvar|event|tri|tri0|tri1|triand|trior|trireg|wand|wor|supply0|supply1|highz0|highz1|small|medium|large|scalared|vectored|signed|unsigned)\\b"
        },
        {
          "name": "storage.type.verilog",
          "match": "\\b(logic|bit|byte|shortint|int|longint|integer|real|realtime|time)\\b"
        },
        {
          "name": "keyword.other.verilog",
          "match": "\\b(posedge|negedge|edge|or|and|nand|nor|xor|xnor|not|buf|bufif0|bufif1|notif0|notif1|pulldown|pullup|cmos|nmos|pmos|rcmos|rnmos|rpmos|rtran|rtranif0|rtranif1|tran|tranif0|tranif1|force|release|strong0|strong1|weak0|weak1|pull0|pull1)\\b"
        },
        {
          "name": "constant.language.verilog",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.verilog",
          "match": "<=|>=|<<<|>>>|<<|>>|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|=="
        },
        {
          "name": "keyword.operator.logical.verilog",
          "match": "&&|\\|\\||!==|===|!=|=="
        },
        {
          "name": "keyword.operator.verilog",
          "match": "[+\\-*/%&|\\^~!=<>?:]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.verilog",
          "match": "\\b[a-zA-Z_]\\w*\\b"
        }
      ]
    }
  },
  "scopeName": "source.verilog"
}
